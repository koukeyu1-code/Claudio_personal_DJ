PORT=8080
# 听众的称呼（DJ 怎么叫你、聊天气泡显示的名字）
LISTENER_NAME=听众
NCM_API_URL=http://localhost:3001
NCM_COOKIE=
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_ENDPOINT=https://api.deepseek.com
DB_PATH=./data/state.db
# 串场音色按歌曲语言切换(均为女声)，全部可选：
# 中文：工作日晓晓 / 周末·假期晓伊；英文：Sonia(英音)；日/韩各一个
TTS_VOICE_WEEKDAY=zh-CN-XiaoxiaoNeural
TTS_VOICE_WEEKEND=zh-CN-XiaoyiNeural
TTS_VOICE_EN=en-GB-SoniaNeural
TTS_VOICE_JA=ja-JP-NanamiNeural
TTS_VOICE_KO=ko-KR-SunHiNeural
# 天气定位优先级：浏览器设备定位 > 下面的固定坐标 > IP 定位。
# 浏览器允许定位后会自动覆盖，一般无需填这三行；仅在用纯后端/无浏览器场景下手填
WEATHER_LAT=
WEATHER_LON=
WEATHER_CITY=
# 飞书日历（可选）。在 open.feishu.cn 建企业自建应用拿到 App ID/Secret，
# 安全设置里把重定向 URL 配成下面的 FEISHU_REDIRECT_URI，开通日历读取权限。
# 配好后访问 /api/feishu/login 扫码授权一次即可
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:8080/api/feishu/callback
